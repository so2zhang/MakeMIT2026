# Copy to .env and fill values.

# Vultr VM SSH (for deploy_vultr_vm.py)
VM_HOST=YOUR_VM_IP
VM_USER=root
VM_PASSWORD=YOUR_VM_ROOT_PASSWORD

# Vultr Managed PostgreSQL
DB_HOST=YOUR_VULTR_DB_HOST
DB_PORT=16751
DB_NAME=defaultdb
DB_USER=vultradmin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SSLMODE=require

# Optional: ingest API base
API_BASE=http://YOUR_VM_IP:8000
